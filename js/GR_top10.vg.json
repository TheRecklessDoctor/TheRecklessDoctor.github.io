{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title":"Top 10 countries with highest population growth rate in 2022.",
    "height": {"step": 17},
     "width" :600,
    "data": { "url": "https://raw.githubusercontent.com/TheRecklessDoctor/TheRecklessDoctor.github.io/master/data/Top10Growth_Rate.csv"},
    
    "transform": [{"filter": "datum['Growth Rate'] > 1.00"}],
    "mark": "bar",
    "encoding": {
      "y": {
        "field": "Country",
        "sort" :"-x",
        "axis": {"grid": false}
      },
      "x": {
        "field": "Growth Rate",
        "aggregate": "mean",
        "title": "population",
        "scale": {"type": "linear"}
        ,"axis": {"grid": false}
      },
      "tooltip":[
        {"field": "Country", "type": "nominal", "title": "Country"},
        {"field": "Growth Rate", "type": "quantitative"}
      ],
      "color": {
        "field": "Continent",
        "type": "nominal"
      }
    },
    "config": {
      "background":"#FFEFD8",
      "style": {
        "cell": {
          "stroke": "transparent"
        }
      }
    }
  }