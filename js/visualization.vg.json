{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "2022 Population by Countries",
  "width": 800,
  "height": 400,
  "projection": {"type": "equalEarth"},
  "data": {
    "url": "https://raw.githubusercontent.com/TheRecklessDoctor/TheRecklessDoctor.github.io/master/data/ne_110m.json",
    "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
  },
  "transform": [
    {
      "lookup": "properties.NAME",
      "from": {
        "data": {
          "url": "https://raw.githubusercontent.com/TheRecklessDoctor/TheRecklessDoctor.github.io/master/data/world_population.csv"
        },
        "key": "Country",
        "fields": ["2022 Population"]
      }
    }
  ],
  "mark": {"type": "geoshape"},
  "encoding": {
    "color": {
      "field": "2022 Population",
      "type": "quantitative",
      "scale": {"domain": [0, 2000000000]}
    },
    "tooltip": [
      {"field": "properties.NAME", "type": "nominal", "title": "Country"},
      {"field": "2022 Population", "type": "quantitative"}
    ]
  }
}